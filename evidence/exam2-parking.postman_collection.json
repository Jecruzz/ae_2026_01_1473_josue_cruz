{
  "info": {
    "name": "Exam2 - Parking Microservice",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "PASTE_YOUR_COGNITO_JWT_HERE" }
  ],
  "item": [
    {
      "name": "1. GET available spaces (public, no token)",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/parking-spaces/available", "host": ["{{baseUrl}}"], "path": ["parking-spaces", "available"] }
      }
    },
    {
      "name": "2. POST entry WITHOUT token (expect 401)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"plate\": \"ABC-123\",\n  \"spaceCode\": \"P1\"\n}" },
        "url": { "raw": "{{baseUrl}}/tickets/entry", "host": ["{{baseUrl}}"], "path": ["tickets", "entry"] }
      }
    },
    {
      "name": "3. POST entry WITH token - happy path (expect 201)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"plate\": \"ABC-123\",\n  \"spaceCode\": \"P1\"\n}" },
        "url": { "raw": "{{baseUrl}}/tickets/entry", "host": ["{{baseUrl}}"], "path": ["tickets", "entry"] }
      }
    },
    {
      "name": "4. POST entry with nonexistent space (expect 404)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"plate\": \"ZZZ-999\",\n  \"spaceCode\": \"NOPE\"\n}" },
        "url": { "raw": "{{baseUrl}}/tickets/entry", "host": ["{{baseUrl}}"], "path": ["tickets", "entry"] }
      }
    },
    {
      "name": "5. POST entry on already occupied space (expect 409)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"plate\": \"DEF-456\",\n  \"spaceCode\": \"P1\"\n}" },
        "url": { "raw": "{{baseUrl}}/tickets/entry", "host": ["{{baseUrl}}"], "path": ["tickets", "entry"] }
      }
    },
    {
      "name": "6. POST exit WITHOUT token (expect 401)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"plate\": \"ABC-123\"\n}" },
        "url": { "raw": "{{baseUrl}}/tickets/exit", "host": ["{{baseUrl}}"], "path": ["tickets", "exit"] }
      }
    },
    {
      "name": "7. POST exit WITH token - happy path (expect 200)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"plate\": \"ABC-123\"\n}" },
        "url": { "raw": "{{baseUrl}}/tickets/exit", "host": ["{{baseUrl}}"], "path": ["tickets", "exit"] }
      }
    },
    {
      "name": "8. POST exit with nonexistent/closed ticket (expect 404)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"plate\": \"ABC-123\"\n}" },
        "url": { "raw": "{{baseUrl}}/tickets/exit", "host": ["{{baseUrl}}"], "path": ["tickets", "exit"] }
      }
    }
  ]
}
